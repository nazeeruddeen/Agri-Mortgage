                                       "w":  12,
                                       "x":  12,
                                       "y":  21
                                   },
                       "targets":  [
                                       {
                                           "expr":  "(sum(rate(http_server_requests_seconds_count{job=\"agri-mortgage-backend\",uri=~\"/api/v1/agri-mortgage-applications.*\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_seconds_count{job=\"agri-mortgage-backend\",uri=~\"/api/v1/agri-mortgage-applications.*\"}[5m])), 0.001))",
                                           "refId":  "A"
