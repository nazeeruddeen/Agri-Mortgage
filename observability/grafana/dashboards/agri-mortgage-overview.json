{
  "title": "Agri Mortgage Backend Overview",
  "uid": "agri-mortgage-overview",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"agri-mortgage-backend\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Pending Documents",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "agri_mortgage_documents_count{state=\"pending\"}", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Gateway Error Cases",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "agri_mortgage_encumbrance_status_count{status=\"gateway_error\"}", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Requested Amount",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "agri_mortgage_amount{kind=\"requested_total\"}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyINR" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Applications by Status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "agri_mortgage_applications_status_count", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Encumbrance Verification States",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "agri_mortgage_encumbrance_status_count", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "Document Readiness",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "targets": [
        { "expr": "agri_mortgage_documents_count", "legendFormat": "{{state}}", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "type": "bargauge",
      "title": "Portfolio Amounts",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "targets": [
        { "expr": "agri_mortgage_amount", "legendFormat": "{{kind}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "currencyINR" } }
    }
  ]
}
