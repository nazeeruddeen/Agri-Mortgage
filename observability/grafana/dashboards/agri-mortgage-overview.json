{
  "title": "Agri Mortgage Backend Overview",
  "uid": "agri-mortgage-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"agri-mortgage-backend\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "Down" }, "1": { "text": "Up" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "HTTP Requests / sec",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(rate(http_server_requests_seconds_count{job=\"agri-mortgage-backend\"}[5m]))", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Heap Used",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"agri-mortgage-backend\",area=\"heap\"})", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Live Threads",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "jvm_threads_live_threads{job=\"agri-mortgage-backend\"}", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Rate",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "sum by (uri) (rate(http_server_requests_seconds_count{job=\"agri-mortgage-backend\",uri!=\"UNKNOWN\"}[5m]))", "legendFormat": "{{uri}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "JVM Heap",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{job=\"agri-mortgage-backend\",area=\"heap\"})", "legendFormat": "heap used", "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{job=\"agri-mortgage-backend\",area=\"heap\"})", "legendFormat": "heap max", "refId": "B" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      }
    }
  ]
}
